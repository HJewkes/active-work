{
  "name": "@titan-design/active-work",
  "version": "0.1.0",
  "type": "module",
  "description": "Durable workspace state for engineering work — CLI, MCP, and Claude skill for tracking initiatives across sessions",
  "license": "MIT",
  "author": "Henry Jewkes",
  "homepage": "https://github.com/HJewkes/active-work",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HJewkes/active-work.git"
  },
  "bugs": {
    "url": "https://github.com/HJewkes/active-work/issues"
  },
  "bin": {
    "active-work": "dist/cli.js",
    "aw": "dist/aw.js"
  },
  "files": [
    "dist",
    "skill",
    "claude-commands",
    "scripts"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup && pnpm build:dashboard",
    "build:cli": "tsup",
    "build:dashboard": "vite build --config src/dashboard/vite.config.ts",
    "gen:cli-reference": "pnpm build:cli && node scripts/gen-cli-reference.mjs",
    "mine:session": "node tools/mine-session-signals.mjs",
    "mine:files": "node tools/mine-file-history.mjs",
    "export:aw-data": "node tools/export-aw-data.mjs",
    "cost:rollup": "node tools/cost-rollup.mjs",
    "eval:miner": "node tools/eval-miner.mjs",
    "check:tools": "for f in tools/*.mjs; do node --check \"$f\" || exit 1; done && node -e \"JSON.parse(require('fs').readFileSync('tools/pricing/models.json','utf8'))\"",
    "postinstall": "node scripts/postinstall.js",
    "preuninstall": "node scripts/preuninstall.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src __tests__ --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"__tests__/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.5",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.20.0",
    "prettier": "^3.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-native-web": "^0.21.2",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vite": "^8.0.12",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.2.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@hono/node-server": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "env-paths": "^4.0.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.18",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
